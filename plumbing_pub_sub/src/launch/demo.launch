<launch>
    <node pkg="plumbing_pub_sub" type="demo02_sub" name="demo02_sub_node" required="true" />
    <node pkg="plumbing_pub_sub" type="demo03_rviz" name="demo03_rviz_node" required="true" />
    <node pkg="rosbag" type="play" args="--loop $(find plumbing_pub_sub)/bag/test.bag" name="test_node" required="true" />
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find plumbing_pub_sub)/rviz/demo.rviz" required="true"/>
</launch>